# Environment Variables — LocallyServe
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL for the backend REST API (no trailing slash)
NEXT_PUBLIC_API_URL=https://api.locallyserve.com

# ─── SITE ─────────────────────────────────────────────────────────────────────
# Canonical site URL (no trailing slash) — used for SEO, OG tags, sitemap
NEXT_PUBLIC_SITE_URL=https://locallyserve.com

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Secret for signing session/JWT tokens (server-side only, NOT NEXT_PUBLIC_)
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_IN_PRODUCTION

# NextAuth.js configuration (if using NextAuth)
NEXTAUTH_URL=https://locallyserve.com
NEXTAUTH_SECRET=CHANGE_ME_IN_PRODUCTION

# ─── OAUTH PROVIDERS ──────────────────────────────────────────────────────────
# Google OAuth — create at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── MAPS / GEOLOCATION ───────────────────────────────────────────────────────
# Google Maps JavaScript API key — restrict to your domain in Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ─── EMAIL ────────────────────────────────────────────────────────────────────
# Resend, Sendgrid, or similar — for newsletter + transactional email
EMAIL_API_KEY=
EMAIL_FROM=hello@locallyserve.com

# ─── ANALYTICS ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── FILE STORAGE ─────────────────────────────────────────────────────────────
# AWS S3 or similar — for provider gig images, profile pictures
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-southeast-1
